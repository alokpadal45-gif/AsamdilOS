{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build AsamdilOS",
            "type": "shell",
            "command": "make",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run AsamdilOS in QEMU",
            "type": "shell",
            "command": "make run",
            "group": "test",
            "dependsOn": "Build AsamdilOS",
            "problemMatcher": []
        },
        {
            "label": "Clean build files",
            "type": "shell",
            "command": "make clean",
            "problemMatcher": []
        }
    ]
}
